+static boolean
+is_wide_character(WCHAR wch)
+{
+    /* Check for CJK character ranges */
+    if ((wch >= 0x3040 && wch <= 0x309F)  /* Hiragana */
+        || (wch >= 0x30A0 && wch <= 0x30FF)  /* Katakana */
+        || (wch >= 0x3400 && wch <= 0x4DBF)  /* CJK Unified Ideographs Extension A */
+        || (wch >= 0x4E00 && wch <= 0x9FFF)  /* CJK Unified Ideographs */
+        || (wch >= 0xAC00 && wch <= 0xD7AF)  /* Hangul Syllables */
+        || (wch >= 0xFF00 && wch <= 0xFFEF)  /* Halfwidth and Fullwidth Forms */
+        || (wch > 0xFF)) {  /* Characters with code > 0xFF (extended Unicode) */
+        return TRUE;
+    }
+    return FALSE;
+}
