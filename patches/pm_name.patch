 const char *
 pmname(struct permonst *pm, int mgender)
 {
     if (mgender < MALE || mgender >= NUM_MGENDERS || !pm->pmnames[mgender])
         mgender = NEUTRAL;
-    return pm->pmnames[mgender];
+    return tra("pm_name", pm->pmnames[mgender]);
 }
