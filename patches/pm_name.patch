 /* mons[]->pmname for a monster */
 const char *
 mon_pmname(struct monst *mon)
 {
     /* for neuter, mon->data->pmnames[MALE] will be Null and use [NEUTRAL] */
     return pmname(mon->data, Mgender(mon));
 }
