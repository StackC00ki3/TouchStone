+static nh_tr_hook_fn nh_tr_hook = (nh_tr_hook_fn) 0;
+
+#if defined(UNIX) || defined(WIN32)
+#define NH_MOD_MAX_HANDLES 64
+#define NH_MOD_DIR "mods"
+#define NH_MOD_PATH_BUFSZ 1024
+#ifdef WIN32
+#define NH_MOD_PATH_SEP "\\"
+typedef HMODULE nh_mod_handle_t;
+#else
+#define NH_MOD_PATH_SEP "/"
+typedef void *nh_mod_handle_t;
+#endif
+
+static nh_mod_handle_t nh_mod_handles[NH_MOD_MAX_HANDLES];
+static int nh_mod_handle_count = 0;
+static boolean nh_mod_loaded = FALSE;
+
+static const struct nh_mod_host_api nh_mod_host_api = {
+    NH_MOD_API_VERSION,
+    nh_mod_set_tr_hook_impl,
+};
+
+staticfn int
+nh_mod_set_tr_hook_impl(nh_tr_hook_fn hook)
+{
+    nh_tr_hook = hook;
+    return 0;
+}
+staticfn boolean
+nh_mod_has_suffix(const char *name, const char *suffix)
+{
+    size_t name_len, suffix_len, i;
+
+    if (!name || !suffix)
+        return FALSE;
+
+    name_len = strlen(name);
+    suffix_len = strlen(suffix);
+    if (name_len < suffix_len)
+        return FALSE;
+
+    for (i = 0; i < suffix_len; ++i) {
+        char a = name[name_len - suffix_len + i];
+        char b = suffix[i];
+
+#ifdef WIN32
+        if (a >= 'A' && a <= 'Z')
+            a = (char) (a - 'A' + 'a');
+        if (b >= 'A' && b <= 'Z')
+            b = (char) (b - 'A' + 'a');
+#endif
+
+        if (a != b)
+            return FALSE;
+    }
+
+    return TRUE;
+}
+
+staticfn boolean
+nh_mod_is_module_file(const char *name)
+{
+    if (!name || !*name)
+        return FALSE;
+
+#ifdef WIN32
+    return nh_mod_has_suffix(name, ".dll") || nh_mod_has_suffix(name, ".so");
+#elif defined(__APPLE__)
+    return nh_mod_has_suffix(name, ".dylib") || nh_mod_has_suffix(name, ".so");
+#else
+    return nh_mod_has_suffix(name, ".so");
+#endif
+}
+
+staticfn void
+nh_mod_try_load_one(const char *path)
+{
+    nh_mod_handle_t handle;
+    nh_mod_init_fn initfn;
+    int init_status;
+
+#ifdef WIN32
+    handle = LoadLibraryA(path);
+    if (!handle) {
+        raw_printf("mod load failed: %s (error=%lu)",
+                   path, (unsigned long) GetLastError());
+        return;
+    }
+
+    initfn = (nh_mod_init_fn) (void *) GetProcAddress(handle,
+                                                       NH_MOD_INIT_SYMBOL);
+    if (!initfn) {
+        raw_printf("mod missing init symbol '%s': %s", NH_MOD_INIT_SYMBOL,
+                   path);
+        (void) FreeLibrary(handle);
+        return;
+    }
+#else
+    handle = dlopen(path, RTLD_NOW);
+    if (!handle) {
+        raw_printf("mod load failed: %s (%s)", path, dlerror());
+        return;
+    }
+
+    initfn = (nh_mod_init_fn) dlsym(handle, NH_MOD_INIT_SYMBOL);
+    if (!initfn) {
+        raw_printf("mod missing init symbol '%s': %s", NH_MOD_INIT_SYMBOL,
+                   path);
+        (void) dlclose(handle);
+        return;
+    }
+#endif
+
+    init_status = (*initfn)(&nh_mod_host_api);
+    if (init_status != 0) {
+        raw_printf("mod init failed (%d): %s", init_status, path);
+#ifdef WIN32
+        (void) FreeLibrary(handle);
+#else
+        (void) dlclose(handle);
+#endif
+        return;
+    }
+
+    if (nh_mod_handle_count < NH_MOD_MAX_HANDLES)
+        nh_mod_handles[nh_mod_handle_count++] = handle;
+    else {
+        raw_printf("mod handle limit reached, unloading: %s", path);
+#ifdef WIN32
+        (void) FreeLibrary(handle);
+#else
+        (void) dlclose(handle);
+#endif
+    }
+}
+#endif
+
+void
+nh_mod_init(void)
+{
+
+#ifdef WIN32
+    WIN32_FIND_DATAA find_data;
+    HANDLE find_handle;
+    char pattern[NH_MOD_PATH_BUFSZ];
+#else
+    DIR *dirp;
+    struct dirent *entry;
+#endif
+
+    if (nh_mod_loaded)
+        return;
+    nh_mod_loaded = TRUE;
+
+#ifdef WIN32
+    Snprintf(pattern, sizeof pattern, "%s\\*.*", NH_MOD_DIR);
+    find_handle = FindFirstFileA(pattern, &find_data);
+    if (find_handle == INVALID_HANDLE_VALUE)
+        return;
+
+    do {
+        const char *name = find_data.cFileName;
+        char path[NH_MOD_PATH_BUFSZ];
+
+        if (!name || name[0] == '.')
+            continue;
+        if ((find_data.dwFileAttributes & FILE_ATTRIBUTE_DIRECTORY) != 0)
+            continue;
+        if (!nh_mod_is_module_file(name))
+            continue;
+
+        Snprintf(path, sizeof path, "%s%s%s", NH_MOD_DIR,
+                 NH_MOD_PATH_SEP, name);
+        nh_mod_try_load_one(path);
+    } while (FindNextFileA(find_handle, &find_data));
+
+    (void) FindClose(find_handle);
+#else
+    dirp = opendir(NH_MOD_DIR);
+    if (!dirp)
+        return;
+
+    while ((entry = readdir(dirp)) != 0) {
+        char path[NH_MOD_PATH_BUFSZ];
+
+        if (!entry->d_name || entry->d_name[0] == '.')
+            continue;
+        if (!nh_mod_is_module_file(entry->d_name))
+            continue;
+
+        Snprintf(path, sizeof path, "%s%s%s", NH_MOD_DIR,
+                 NH_MOD_PATH_SEP, entry->d_name);
+        nh_mod_try_load_one(path);
+    }
+    (void) closedir(dirp);
+#endif
+}
+
+const char *
+tra(const char *key, const char *fallback)
+{
+    if (!key || !*key)
+        return fallback;
+
+    if (nh_tr_hook) {
+        const char *translated = (*nh_tr_hook)(key, fallback);
+
+        if (translated)
+            return translated;
+    }
+
+    return fallback;
+}
