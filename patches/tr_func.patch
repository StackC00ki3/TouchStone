 /* mode values for findtravelpath() */
 #define TRAVP_TRAVEL 0
 #define TRAVP_GUESS  1
 #define TRAVP_VALID  2
 
+struct tr_static_entry {
+    const char *key;
+    const char *value;
+};
+
+static const struct tr_static_entry tr_table_data[] = {
+#include "tr_table_data.inc"
+};
+
+#define TR_TABLE_COUNT ((int) SIZE(tr_table_data))
+
+const char *
+tr(const char *key, const char *fallback)
+{
+    int lo = 0, hi = TR_TABLE_COUNT - 1;
+
+    if (!key || !*key)
+        return fallback;
+
+    while (lo <= hi) {
+        int mid = lo + ((hi - lo) / 2);
+        int cmp = strcmp(key, tr_table_data[mid].key);
+
+        if (cmp == 0) {
+            const char *v = tr_table_data[mid].value;
+            return (v && *v) ? v : fallback;
+        }
+        if (cmp < 0)
+            hi = mid - 1;
+        else
+            lo = mid + 1;
+    }
+    return fallback;
+}
