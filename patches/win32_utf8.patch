--- a/win/win32/NetHackW.c
+++ b/win/win32/NetHackW.c
@@ -428,10 +428,102 @@ _nhapply_image_transparent(HDC hDC, int x, int y, int width, int height,
     DeleteObject(SelectObject(hdcMem, bmMemOld));
     DeleteObject(SelectObject(hdcSave, bmSaveOld));
 
     DeleteDC(hdcMem);
     DeleteDC(hdcBack);
     DeleteDC(hdcObject);
